#!/usr/bin/env ruby
# frozen_string_literal: true

# Start the Brute HTTP server.
#
#   brute-server                          # Run default examples/service.rb
#   brute-server my_service.rb            # Run a custom service config
#   brute-server examples/restricted.rb   # Run the restricted example
#
# With async-service installed (recommended):
#   Uses async-service to manage the process lifecycle.
#
# Without async-service (fallback):
#   Uses rackup + WEBrick with examples/config.ru.

config = ARGV.shift || File.expand_path("../examples/service.rb", __dir__)

begin
  require "async/service"
  $stderr.puts "brute-server: #{config}"
  exec("async-service", config, *ARGV)
rescue LoadError
  $stderr.puts "brute-server: async-service not found, falling back to rackup"
  require "brute_rack"
  require "rackup"
  Rackup::Server.start(config: BruteRack.config_ru_path, Port: 9292)
end
